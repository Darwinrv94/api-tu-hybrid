generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model archivo_licencia {
  id_archivo           Int                  @id @default(autoincrement())
  ruta_pin             String               @db.Text
  ruta_pdf             String               @db.Text
  id_asignacion        Int
  asignacion_licencias asignacion_licencias @relation(fields: [id_asignacion], references: [id_asignacion], onDelete: Cascade, map: "archivo_licencia_ibfk_1")

  @@index([id_asignacion], map: "id_asignacion")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asesores {
  id_asesor          Int                  @id @default(autoincrement())
  nombre             String               @db.VarChar(70)
  nombre_empresa     String               @db.VarChar(70)
  pais               String               @db.VarChar(30)
  ciudad             String               @db.VarChar(30)
  prefijo            String               @db.VarChar(10)
  numero             String               @db.VarChar(30)
  cod_postal         Int
  id_fiscal          String               @db.VarChar(30)
  persona_contacto   String               @db.VarChar(70)
  direccion_fiscal   String               @db.VarChar(200)
  direccion_envio    String               @db.VarChar(200)
  id_distribuidor    Int?
  id_subdistribuidor Int?
  id_usuario         Int
  permitirEditar     Boolean              @default(false)
  atencion_actividad atencion_actividad[]

  @@index([id_distribuidor], map: "id_distribuidor")
  @@index([id_distribuidor], map: "id_distribuidor_2")
  @@index([id_subdistribuidor], map: "id_subdistribuidor")
  @@index([id_usuario], map: "id_usuario")
  @@index([id_usuario], map: "id_usuario_2")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model asignacion_licencias {
  id_asignacion                 Int                @id @default(autoincrement())
  producto                      String             @db.VarChar(200)
  licencia                      String             @db.VarChar(200)
  status                        Boolean
  grupo                         Int
  id_usuario                    Int
  fecha_asignacion              DateTime?          @db.Timestamp(0)
  tipo_documento                Int?
