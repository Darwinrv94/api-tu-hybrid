  asesores            asesores            @relation(fields: [id_asesor], references: [id_asesor], onDelete: NoAction, onUpdate: NoAction, map: "atencion_actividad_ibfk_2")
  cliente_final       cliente_final       @relation(fields: [id_cliente], references: [id_cliente_final], onDelete: NoAction, onUpdate: NoAction, map: "atencion_actividad_ibfk_3")

  @@index([id_actividad], map: "id_actividad")
